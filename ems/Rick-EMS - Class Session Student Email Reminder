      font-weight: 500;
      margin-bottom: 5px;
      display: block;
    }

    /* Toast */
    #se-toast {
      position: fixed;
      bottom: 90px;
      right: 28px;
      background: #1a3a5c;
      color: #fff;
      padding: 10px 18px;
      border-radius: 9px;
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      z-index: 999999;
