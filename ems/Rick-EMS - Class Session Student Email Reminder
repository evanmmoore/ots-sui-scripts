  // ─── Helpers ───────────────────────────────────────────────────────────────

  function initials(name) {
    return name.trim().split(/\s+/).map(w => w[0] || '').join('').toUpperCase().slice(0, 2);
  }

  function toast(msg, duration = 2800) {
    let t = document.getElementById('se-toast');
    if (!t) { t = document.createElement('div'); t.id = 'se-toast'; document.body.appendChild(t); }
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), duration);
  }

  // ─── Scrape students from page ─────────────────────────────────────────────
  function scrapeStudents() {
    const students = [];
    const seen = new Set();

    document.querySelectorAll('table tbody tr').forEach(row => {
      // Name + student number from .student-name a
      const nameEl = row.querySelector('.student-name a');
      if (!nameEl) return;

      const name = nameEl.textContent.trim();
      const studentNumber = (nameEl.href || '').match(/student_number=(\d+)/)?.[1] || '';

      // Email from mailto link
      const mailtoEl = row.querySelector('a[href^="mailto:"]');
      const email = mailtoEl ? mailtoEl.href.replace('mailto:', '').split('?')[0].trim() : '';

      if (!seen.has(studentNumber || email)) {
        seen.add(studentNumber || email);
        students.push({ name, email, studentNumber });
      }
    });

    return students;
  }

  // ─── Scrape session info from page ────────────────────────────────────────
  function scrapeSessionInfo() {
    const info = { name: '', date: '', time: '', facility: '', address: '' };

    // Helper: find a detail-item whose strong label matches, return the span text
    function getDetailItem(labelText) {
      const items = document.querySelectorAll('.detail-item');
      for (const item of items) {
        const strong = item.querySelector('strong');
        if (strong && strong.textContent.trim().toLowerCase().includes(labelText.toLowerCase())) {
          const span = item.querySelector('span');
          if (span) return span.textContent.trim();
          // fallback: text after the strong tag
          return item.textContent.replace(strong.textContent, '').trim();
        }
      }
      return '';
    }

    const rawName = getDetailItem('Calendar Display Name')
      .replace(/&amp;reg;/gi, '')
      .replace(/&reg;/gi, '')
      .replace(/®/g, '')
      .replace(/\s+/g, ' ')
      .trim();

    // Extract time range like "8:00 AM - 3:30 PM" from the name
    const timeRangeMatch = rawName.match(/(\d{1,2}:\d{2}\s*(?:AM|PM)\s*[-–]\s*\d{1,2}:\d{2}\s*(?:AM|PM))/i);
    info.timeRange = timeRangeMatch ? timeRangeMatch[1].trim() : '';

    info.name = rawName
      .replace(/\s+\d{1,2}:\d{2}\s*(AM|PM)\s*[-–]\s*\d{1,2}:\d{2}\s*(AM|PM)/i, '')
      .replace(/\s+Courses?\s*$/i, '')
      .replace(/\s+/g, ' ')
      .trim();
    info.date = getDetailItem('Date');
    info.time = getDetailItem('Time');

    // Facility section
    const facilitySections = document.querySelectorAll('.detail-section');
    for (const section of facilitySections) {
      const title = section.querySelector('.section-title');
      if (title && title.textContent.trim().toLowerCase() === 'facility') {
        const items = [...section.querySelectorAll('.detail-item')];
        // First item is the facility name link, rest are address lines
        if (items[0]) info.facility = items[0].textContent.trim();
        const addrLines = items.slice(1).map(i => i.textContent.trim()).filter(Boolean);
        info.address = addrLines.join(', ');
        break;
      }
    }

    return info;
  }

  // ─── Build UI ──────────────────────────────────────────────────────────────
  function buildUI(students, session, trigger) {
    // Remove any existing backdrop
    document.getElementById('se-backdrop')?.remove();

    // Backdrop + panel
    const backdrop = document.createElement('div');
    backdrop.id = 'se-backdrop';
    backdrop.innerHTML = `
      <div id="se-panel">
        <div id="se-header">
          <div>
            <h2>📧 Email Students</h2>
            <p id="se-student-count">0 students found in this session</p>
          </div>
          <button id="se-close" title="Close">✕</button>
        </div>

        <div id="se-toolbar">
          <input id="se-search" type="text" placeholder="Search by name or email…">
          <button class="se-toolbar-btn" id="se-select-all">Select All</button>
          <button class="se-toolbar-btn" id="se-clear-all">Clear</button>
        </div>

        <div id="se-list"></div>

        <div id="se-subject-row">
          <label class="se-subject-label" for="se-subject">Email Subject</label>
          <input id="se-subject" type="text" placeholder="e.g. Important update from your OT Systems session">
        </div>

        <div id="se-footer">
          <div id="se-count">Selected: <span id="se-sel-count">0</span> / ${students.length}</div>
          <button id="se-send" disabled>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            Open in Outlook
          </button>
        </div>
      </div>`;
    document.body.appendChild(backdrop);

    const listEl      = document.getElementById('se-list');
    const searchEl    = document.getElementById('se-search');
    const selCountEl  = document.getElementById('se-sel-count');
    const sendBtn     = document.getElementById('se-send');
    const selectAllBtn = document.getElementById('se-select-all');
    const clearBtn    = document.getElementById('se-clear-all');
    const subjectEl   = document.getElementById('se-subject');
    subjectEl.value   = session.name ? `Reminder: Upcoming Class – ${session.name}` : '';

    let selected = new Set();

    // ── Render list ──
    function renderList(filter = '') {
      listEl.innerHTML = '';
      const q = filter.toLowerCase();
      const visible = students.filter(s =>
        s.name.toLowerCase().includes(q) || s.email.toLowerCase().includes(q)
      );

      if (visible.length === 0) {
        listEl.innerHTML = `
          <div id="se-empty">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <div>No students match your search.</div>
          </div>`;
        return;
      }

      visible.forEach(s => {
        const row = document.createElement('div');
        row.className = 'se-student' + (selected.has(s.email) ? ' selected' : '');
        row.dataset.email = s.email;
        row.innerHTML = `
          <input type="checkbox" ${selected.has(s.email) ? 'checked' : ''}>
          <div class="se-info">
            <div class="se-name">${s.studentNumber
              ? `<a href="https://otsystems.net/admin/students/dashboard/?student_number=${s.studentNumber}" target="_blank" style="color:#1a3a5c;text-decoration:underline;font-weight:600;">${s.name}</a>`
              : s.name
            }${s.studentNumber ? `<span style="font-weight:400;color:#607080;font-size:11.5px;margin-left:7px;">S# ${s.studentNumber}</span>` : ''}</div>
            <div class="se-email">${s.email || '<span style="opacity:.5">no email found</span>'}</div>
          </div>`;

        row.addEventListener('click', (e) => {
          if (e.target.tagName === 'A') return; // let link open normally
          const chk = row.querySelector('input');
          if (selected.has(s.email)) {
            selected.delete(s.email);
            row.classList.remove('selected');
            chk.checked = false;
          } else {
            selected.add(s.email);
            row.classList.add('selected');
            chk.checked = true;
          }
          updateCount();
        });

        listEl.appendChild(row);
      });
    }

    function updateCount() {
      selCountEl.textContent = selected.size;
      sendBtn.disabled = selected.size === 0;
    }

    renderList();

    // ── Toolbar actions ──
    searchEl.addEventListener('input', () => renderList(searchEl.value));

    selectAllBtn.addEventListener('click', () => {
      students.forEach(s => selected.add(s.email));
      renderList(searchEl.value);
      updateCount();
    });

    clearBtn.addEventListener('click', () => {
      selected.clear();
      renderList(searchEl.value);
      updateCount();
    });

    // ── Open / Close ──
    trigger.addEventListener('click', () => {
      // Re-scrape on every open so we always get the latest rendered table
      const fresh = scrapeStudents();
      console.log('[SE] fresh scrape on click:', fresh.length, fresh);
      // Replace entire list with fresh data
      students.length = 0;
      fresh.forEach(s => students.push(s));
      // Update header count
      const countEl = document.getElementById('se-student-count');
      if (countEl) countEl.textContent = `${students.length} student${students.length !== 1 ? 's' : ''} found in this session`;
      renderList(searchEl.value);
      updateCount();
      backdrop.classList.add('open');
      searchEl.focus();
    });

    document.getElementById('se-close').addEventListener('click', () => {
      backdrop.classList.remove('open');
    });

    backdrop.addEventListener('click', e => {
      if (e.target === backdrop) backdrop.classList.remove('open');
    });

    // ── Send ──
    sendBtn.addEventListener('click', () => {
      const subject = subjectEl.value.trim() ||
        `Reminder: Upcoming Class – ${session.name || 'Your Upcoming Class'}`;

      const body = [
        'This is an automated reminder for your upcoming class:',
        '',
        `Class: ${session.name  || '(see session page)'}`,
        `Date: ${session.date  || '(see session page)'}`,
        `Class Time: ${session.time  || '(see session page)'}${session.timeRange ? ' – ' + session.timeRange : ''}`,
        `Location: ${session.facility ? session.facility + (session.address ? ' – ' + session.address : '') : '(see session page)'}`,
        '',
        'Please arrive on time or 15 minutes early.',
        '',
        'If you have any questions, feel free to reach out.',
      ].join('\r\n');

      // ── Step 1: Open Outlook immediately ──
      const mailto = `mailto:?bcc=${encodeURIComponent([...selected].join(';'))}&subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailto;

      // ── Step 2: Store batch note job, open note-batch page after 3s ──
      const selectedStudents = students.filter(s => selected.has(s.email));
      const withNumbers = selectedStudents.filter(s => s.studentNumber);

      if (withNumbers.length > 0) {
        const noteText = `Sent email reminder for upcoming class: ${session.name || 'N/A'} on ${session.date || 'N/A'}`;
        GM_setValue('se_batch_note', JSON.stringify({
          studentNumbers: withNumbers.map(s => s.studentNumber),
          note: noteText,
          ts: Date.now(),
        }));

        toast(`✅ Outlook opening… notes tab will open in 3 seconds`);

        setTimeout(() => {
          window.open('https://admin.otsystems.net/#/note-batch/create', '_blank');
        }, 3000);
      } else {
        toast(`✅ Opening Outlook with ${selected.size} recipient${selected.size !== 1 ? 's' : ''} in BCC…`);
      }
    });

    // ── No students found ──
    if (students.length === 0) {
      listEl.innerHTML = `
        <div id="se-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
          <div style="font-weight:600;color:#1a2a3a;margin-bottom:6px;">No students found</div>
          <div>Could not detect any student emails on this page.<br>Make sure the student list has fully loaded.</div>
        </div>`;
    }
  }

  // ─── Init ──────────────────────────────────────────────────────────────────
  function init(trigger) {
    const students = scrapeStudents();
    const session  = scrapeSessionInfo();
    console.log('[SE] init() students:', students.length, students);
    buildUI(students, session, trigger);
  }

  // ─── Batch note worker — runs on admin.otsystems.net/#/note-batch/create ────
  let batchWorkerRan = false;
  function batchNoteWorker() {
    if (batchWorkerRan) return;
    batchWorkerRan = true;

    let payload;
    try {
      const raw = GM_getValue('se_batch_note', '');
      if (!raw) return;
      payload = JSON.parse(raw);
    } catch(e) { return; }

    if (Date.now() - payload.ts > 300000) { GM_deleteValue('se_batch_note'); return; }

    const { studentNumbers, note } = payload;

    function waitFor(selectorFn, timeout, cb) {
      const start = Date.now();
      const t = setInterval(() => {
        const el = selectorFn();
        if (el) { clearInterval(t); cb(el); return; }
        if (Date.now() - start > timeout) { clearInterval(t); cb(null); }
      }, 300);
    }

    function angularSet(input, value) {
      input.focus();
      input.value = value;
      angular.element(input).triggerHandler('input');
      angular.element(input).triggerHandler('change');
    }

    function addStudents(numbers, idx, done) {
      if (idx >= numbers.length) { done(); return; }

      waitFor(
        () => document.querySelector('input[ng-model="nbc.SearchNumber"]'),
        8000,
        (input) => {
          if (!input) { console.warn('[SE] Search input not found'); done(); return; }

          angularSet(input, numbers[idx]);

          setTimeout(() => {
            const searchBtn = [...document.querySelectorAll('button')]
              .find(b => b.textContent.trim() === 'Search');
            if (searchBtn) {
              try { angular.element(searchBtn).triggerHandler('click'); } catch(e) { searchBtn.click(); }
            }

            setTimeout(() => {
              const addBtn = [...document.querySelectorAll('button')]
                .find(b => b.textContent.trim() === 'Add Student');
              if (addBtn) {
                try { angular.element(addBtn).triggerHandler('click'); } catch(e) { addBtn.click(); }
                console.log(`[SE] Added student ${numbers[idx]}`);
              }
              setTimeout(() => addStudents(numbers, idx + 1, done), 800);
            }, 1000);
          }, 600);
        }
      );
    }

    waitFor(
      () => document.querySelector('input[ng-model="nbc.SearchNumber"]'),
      15000,
      (input) => {
        if (!input) { console.warn('[SE] Batch note page not ready'); return; }

        addStudents(studentNumbers, 0, () => {
          // Inject note into CKEditor
          waitFor(
            () => document.querySelector('iframe.cke_wysiwyg_frame'),
            8000,
            (editorFrame) => {
              if (!editorFrame) { console.warn('[SE] CKEditor not found'); return; }

              setTimeout(() => {
                try {
                  const editorDoc = editorFrame.contentDocument || editorFrame.contentWindow?.document;
                  editorDoc.body.focus();
                  editorDoc.execCommand('selectAll', false, null);
                  editorDoc.execCommand('insertText', false, note);
                  console.log('[SE] Note injected');
                } catch(e) { console.warn('[SE] CKEditor inject failed:', e); }

                // Show instruction banner
                setTimeout(() => {
                  const banner = document.createElement('div');
                  banner.id = 'se-confirm-banner';
                  banner.style.cssText = [
                    'position:fixed', 'bottom:28px', 'right:28px', 'z-index:2147483647',
                    'background:#1a3a5c', 'color:#fff', 'padding:18px 22px',
                    'border-radius:12px', 'font-family:sans-serif', 'font-size:14px',
                    'box-shadow:0 6px 24px rgba(0,0,0,.4)', 'line-height:1.5', 'max-width:360px',
                  ].join(';');
                  banner.innerHTML = `
                    <div style="font-weight:600;margin-bottom:6px;">📝 Note Ready</div>
                    <div style="font-size:12px;opacity:.85;margin-bottom:10px;">${note}</div>
                    <div style="font-size:12.5px;background:rgba(255,255,255,.15);border-radius:8px;padding:10px 12px;margin-bottom:14px;">
