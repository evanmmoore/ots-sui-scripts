                }, 800);
              }, 800);
            }
          );
        });
      }
    );
  }

  // ─── Router ────────────────────────────────────────────────────────────────
  if (location.hostname === 'admin.otsystems.net') {
    function tryBatchWorker() {
      if (location.hash.includes('note-batch') && !batchWorkerRan) {
        setTimeout(batchNoteWorker, 1000);
      }
    }
    tryBatchWorker();
    window.addEventListener('hashchange', tryBatchWorker);
  } else if (location.hostname === 'admin2025.otsystems.net') {
    // Session page UI
    function injectEmailBtn() {
      if (document.getElementById('se-trigger')) return;
      const printBtn = document.querySelector('.print-student-list-btn');
      if (!printBtn) return;
      console.log('[SE] Building UI...');
      try {
        const trigger = document.createElement('button');
        trigger.id = 'se-trigger';
        trigger.textContent = 'Class Reminder';
        trigger.setAttribute('style', [
          'display:inline-flex',
          'align-items:center',
          'gap:6px',
          'padding:5px 14px',
          'background:#1a3a5c',
          'color:#fff',
          'border:none',
          'border-radius:6px',
          'font-family:sans-serif',
          'font-size:13px',
          'font-weight:600',
          'cursor:pointer',
          'margin-right:6px',
          'vertical-align:middle',
        ].join(';'));
        // Wrap trigger + print button in a flex div so they sit together on the right
        const wrapper = document.createElement('div');
        wrapper.id = 'se-btn-wrapper';
        wrapper.style.cssText = 'display:flex;align-items:center;gap:6px;';
        printBtn.parentElement.replaceChild(wrapper, printBtn);
        wrapper.appendChild(trigger);
        wrapper.appendChild(printBtn);
        init(trigger);
        console.log('[SE] init() completed, trigger:', document.getElementById('se-trigger'));
      } catch(e) {
        console.error('[SE] CRASH in init():', e);
      }
    }

    const observer = new MutationObserver(() => {
      if (!document.getElementById('se-trigger')) injectEmailBtn();
    });
    observer.observe(document.body, { childList: true, subtree: true });
    injectEmailBtn();
  }

})();
